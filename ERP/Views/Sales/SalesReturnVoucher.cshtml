@model ERP.Models.PurchaseViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Sales Return Voucher";
    var salesList = ViewBag.Sales as List<ERP.Models.SalesListDto>;
    int currentPage  = (int)(ViewBag.Page      ?? 1);
    int pageSize     = (int)(ViewBag.PageSize   ?? 5);
    int totalItems   = (int)(ViewBag.TotalItems ?? 0);
    string activeTab = ViewBag.ActiveTab as string ?? "form";
    int startItem    = totalItems == 0 ? 0 : (currentPage - 1) * pageSize + 1;
    int endItem      = Math.Min(currentPage * pageSize, totalItems);
    int totalPages   = totalItems == 0 ? 1 : (int)Math.Ceiling((double)totalItems / pageSize);
}

<div class="space-y-8">
    <!-- TABS -->
    <div class="border-b border-gray-300 bg-white shadow-sm rounded-xl p-2">
        <nav class="flex space-x-6" aria-label="Tabs">
            <button id="tab-form" type="button"
                    class="px-4 py-2 text-sm font-semibold @(activeTab == "form" ? "text-blue-900 border-b-2 border-blue-900" : "text-gray-500 hover:text-blue-900")">
                <i class="fa-solid fa-plus-circle mr-2"></i> Sales Return Entry
            </button>
            <button id="tab-list" type="button"
                    class="px-4 py-2 text-sm font-semibold @(activeTab == "list" ? "text-blue-900 border-b-2 border-blue-900" : "text-gray-500 hover:text-blue-900")">
                <i class="fa-solid fa-list mr-2"></i> Sales Return List
            </button>
        </nav>
    </div>

    <!-- FORM TAB -->
    <div id="content-form" class="@(activeTab == "list" ? "hidden" : "")">

        @* ✅ Form action = SalesReturn Controller *@
        @using (Html.BeginForm("Create", "SalesReturn", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.StockMaster.Id, new { id = "StockMasterId" })
            @Html.HiddenFor(m => m.StockMaster.companyId)
            @Html.HiddenFor(m => m.StockMaster.userId)
            @* ✅ etype = SalesReturn *@
            <input type="hidden" name="StockMaster.etype" value="SalesReturn" />

            <!-- Header -->
            <div class="shadow-lg rounded-2xl bg-gradient-to-r from-blue-50 to-blue-100 p-6 border border-gray-200">
                <div class="flex justify-between items-center">
                    <div>
                        <h2 class="text-2xl font-bold text-blue-800 flex items-center gap-2">
                            <i class="fa-solid fa-rotate-left text-blue-700"></i> Sales Return Voucher
                        </h2>
                        <p class="text-gray-600 mt-1 text-sm">Add and manage sales return voucher details</p>
                    </div>
                    <div class="flex space-x-2">
                        <button type="submit" onclick="return beforeSave()"
                                class="px-5 py-2.5 rounded-xl text-sm font-semibold text-white bg-green-600 hover:bg-green-700 shadow-md transition">
                            <i class="fa-solid fa-save mr-2"></i> Save
                        </button>
                        <button type="button" onclick="resetForm()"
                                class="px-5 py-2.5 rounded-xl text-sm font-semibold text-gray-700 bg-yellow-300 hover:bg-yellow-400 shadow-md transition">
                            <i class="fa-solid fa-rotate-right mr-2"></i> Reset
                        </button>
                        <button type="button" onclick="printVoucher()"
                                class="px-5 py-2.5 rounded-xl text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 shadow-md transition">
                            <i class="fa-solid fa-print mr-2"></i> Print
                        </button>
                       
                    </div>
                </div>
            </div>

            <!-- Main Fields -->
            <div class="shadow-md rounded-2xl bg-white p-6 border border-gray-200 mt-4">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label class="block font-semibold text-gray-700 mb-1">Current Date <sup class="text-red-800 text-lg">*</sup></label>
                        @Html.TextBoxFor(m => m.StockMaster.current_date, "{0:yyyy-MM-dd}",
                            new { @class = "w-full p-2 border rounded-lg focus:ring-2 focus:ring-blue-500", type = "date", required = "required" })
                    </div>
                    <div>
                        <label class="block font-semibold text-gray-700 mb-1">Due Date <sup class="text-red-800 text-lg">*</sup></label>
                        @Html.TextBoxFor(m => m.StockMaster.due_date, "{0:yyyy-MM-dd}",
                            new { @class = "w-full p-2 border rounded-lg focus:ring-2 focus:ring-blue-500", type = "date", required = "required" })
                    </div>
                    <div>
                        <label class="block font-semibold text-gray-700 mb-1">Posted Date <sup class="text-red-800 text-lg">*</sup></label>
                        @Html.TextBoxFor(m => m.StockMaster.posted_date, "{0:yyyy-MM-dd}",
                            new { @class = "w-full p-2 border rounded-lg focus:ring-2 focus:ring-blue-500", type = "date", required = "required" })
                    </div>
                </div>

                <!-- Customer + Remarks (No Payment Method - Sales Return mein nahi hota) -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
                    <div>
                        <label class="block font-semibold text-gray-700 mb-1">
                            Customer <sup class="text-red-800 text-lg">*</sup>
                            <a href="javascript:void(0)" onclick="openCustomerModal()"
                               class="inline-flex items-center px-3 py-1 text-xs text-blue-600 font-semibold hover:text-blue-800">
                                <i class="fa-solid fa-plus mr-1"></i> Add New
                            </a>
                        </label>
                        <select id="customerId" name="StockMaster.customerId"
                                class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-blue-500" required>
                            <option value="">Select Customer</option>
                            @foreach (var customer in ViewBag.Customers)
                            {
                                <option value="@customer.Id"
                                        selected="@(Model.StockMaster.customerId == customer.Id ? "selected" : null)">
                                    @customer.name
                                </option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block font-semibold text-gray-700 mb-1">Remarks</label>
                        @Html.TextAreaFor(m => m.StockMaster.remarks,
                            new { @class = "w-full p-2 border rounded-lg focus:ring-2 focus:ring-blue-500 resize-none",
                                  rows = "2", placeholder = "Enter Remarks" })
                    </div>
                </div>
            </div>

            <!-- Stock Details Section -->
            <div class="shadow-md rounded-2xl bg-white p-6 border mt-4">
                <nav class="flex space-x-6 mb-4 border-b pb-2">
                    <button id="tab-stock-details" type="button"
                            class="px-4 py-2 text-sm font-semibold text-blue-900 border-b-2 border-blue-900">
                        <i class="fa-solid fa-box mr-2"></i> Stock Details
                    </button>
                    <button id="tab-additional-charges" type="button"
                            class="px-4 py-2 text-sm font-semibold text-gray-500 hover:text-blue-900">
                        <i class="fa-solid fa-money-bill mr-2"></i> Additional Charges
                    </button>
                </nav>

                <!-- Stock Details -->
                <div id="content-stock-details">
                    <h3 class="text-lg font-semibold mb-4 text-gray-800">Add Return Items</h3>
                    <div class="grid grid-cols-12 gap-4 items-end">
                        <div class="col-span-12 md:col-span-4">
                            <label class="block font-semibold text-gray-700 mb-1">
                                Warehouse <sup class="text-red-800 text-lg">*</sup>
                                <a href="javascript:void(0)" onclick="openWarehouseModal()"
                                   class="inline-flex items-center px-3 py-1 text-xs text-blue-600 font-semibold">
                                    <i class="fa-solid fa-plus mr-1"></i> Add New
                                </a>
                            </label>
                            <select id="warehouseId" class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-blue-500">
                                <option value="">Select Warehouse</option>
                                @foreach (var warehouse in ViewBag.Warehouses as IEnumerable<dynamic>)
                                {
                                    <option value="@warehouse.Id">@warehouse.warehouse_name</option>
                                }
                            </select>
                        </div>
                        <div class="col-span-12 md:col-span-4">
                            <label class="block font-semibold text-gray-700 mb-1">
                                Item <sup class="text-red-800 text-lg">*</sup>
                                <a href="javascript:void(0)" onclick="openItemModal()"
                                   class="inline-flex items-center px-3 py-1 text-xs text-blue-600 font-semibold">
                                    <i class="fa-solid fa-plus mr-1"></i> Add New
                                </a>
                            </label>
                            <select id="itemId" class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-blue-500"
                                    onchange="fetchSalesRate()">
                                <option value="">Select Item</option>
                                @foreach (var item in ViewBag.Items as IEnumerable<dynamic>)
                                {
                                    <option value="@item.Id">@item.item_name</option>
                                }
                            </select>
                        </div>
                        <div class="col-span-6 md:col-span-2">
                            <label class="block font-semibold text-gray-700 mb-1">Rate <sup class="text-red-800 text-lg">*</sup></label>
                            <input type="number" id="rate" step="0.01" min="0" placeholder="0.00"
                                   class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-blue-500" />
                        </div>
                        <div class="col-span-6 md:col-span-2">
                            <label class="block font-semibold text-gray-700 mb-1">Quantity <sup class="text-red-800 text-lg">*</sup></label>
                            <input type="number" id="qty" min="1" placeholder="0"
                                   class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-blue-500" />
                        </div>
                        <div class="col-span-6 md:col-span-2">
                            <label class="block font-semibold text-gray-700 mb-1">Amount</label>
                            <input type="number" id="amount" step="0.01" readonly placeholder="0.00"
                                   class="w-full p-2 border rounded-lg bg-gray-50" />
                        </div>
                        <div class="col-span-6 md:col-span-3">
                            <label class="block font-semibold text-gray-700 mb-1">Discount %</label>
                            <input type="number" id="discount_percentage" step="0.01" min="0" max="100" placeholder="0.00"
                                   class="w-full p-2 border rounded-lg focus:ring-2 focus:ring-blue-500" />
                        </div>
                        <div class="col-span-6 md:col-span-2">
                            <label class="block font-semibold text-gray-700 mb-1">Disc Amt</label>
                            <input type="number" id="discount_amount" readonly step="0.01" placeholder="0.00"
                                   class="w-full p-2 border rounded-lg bg-gray-50" />
                        </div>
                        <div class="col-span-6 md:col-span-3">
                            <label class="block font-semibold text-gray-700 mb-1">Net Amount</label>
                            <input type="number" id="net_amount" readonly step="0.01" placeholder="0.00"
                                   class="w-full p-2 border rounded-lg bg-gray-50 font-bold text-green-700" />
                        </div>
                      <div class="col-span-2">
                            <button type="button" id="btnAddDetail"
                                    class="px-5 py-2 rounded-xl text-sm font-semibold text-white bg-blue-900">
                                Add
                            </button>
                        </div>
                    </div>
                    <div id="addMessage" class="hidden mt-2 px-4 py-2 rounded-lg text-sm font-semibold"></div>
                     <div class="overflow-hidden border rounded-lg mt-6">
                        <div class="max-h-96 overflow-y-auto">
                            <table class="table-auto w-full text-sm" id="detailsTable">
                                <thead class="bg-gradient-to-r from-blue-800 to-blue-900 text-white">
                                    <tr>
                                        <th class="p-3">S.No</th>
                                        <th class="p-3">Date</th>
                                        <th class="p-3">Warehouse</th>
                                        <th class="p-3">Item</th>
                                        <th class="p-3">Qty</th>
                                        <th class="p-3">Rate</th>
                                        <th class="p-3">Amount</th>
                                        <th class="p-3">Dis %</th>
                                        <th class="p-3">Dis Amt</th>
                                        <th class="p-3">Net Amt</th>
                                        <th class="p-3">Action</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                
                      </div>

                <!-- Additional Charges -->
                <div id="content-additional-charges" class="hidden">
                    <h3 class="text-lg font-semibold mb-4 text-gray-800">Additional Charges</h3>
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                        <div>
                            <label class="block font-semibold text-gray-700 mb-1">Total Amount</label>
                            @Html.TextBoxFor(m => m.StockMaster.total_amount,
                                new { @class = "w-full p-2 border rounded-lg bg-gray-50", type = "number", step = "0.01", @readonly = "readonly" })
                        </div>
                        <div>
                            <label class="block font-semibold text-gray-700 mb-1">Discount Amount</label>
                            @Html.TextBoxFor(m => m.StockMaster.discount_amount,
                                new { @class = "w-full p-2 border rounded-lg focus:ring-2 focus:ring-blue-500", type = "number", step = "0.01", @onchange = "updateNetAmount()", placeholder = "0.00" })
                        </div>
                        <div>
                            <label class="block font-semibold text-gray-700 mb-1">Tax Amount</label>
                            @Html.TextBoxFor(m => m.StockMaster.tax_amount,
                                new { @class = "w-full p-2 border rounded-lg focus:ring-2 focus:ring-blue-500", type = "number", step = "0.01", @onchange = "updateNetAmount()", placeholder = "0.00" })
                        </div>
                        <div>
                            <label class="block font-semibold text-gray-700 mb-1">Net Amount</label>
                            @Html.TextBoxFor(m => m.StockMaster.net_amount,
                                new { @class = "w-full p-2 border rounded-lg bg-gray-50 font-bold text-green-700", type = "number", step = "0.01", @readonly = "readonly" })
                        </div>
                    </div>
                </div>
            </div>
            <div id="detailsContainer"></div>
        }
    </div>

    <!-- LIST TAB -->
    <div id="content-list" class="@(activeTab == "list" ? "" : "hidden") shadow-lg rounded-2xl bg-white p-6 border">
        <div class="flex justify-between items-center mb-6">
            <div>
                <h2 class="text-2xl font-bold text-blue-800">
                    <i class="fa-solid fa-list-ul mr-2"></i> Sales Return List
                </h2>
                <p class="text-gray-500 text-sm mt-1">Manage all sales return vouchers</p>
            </div>
            <div class="flex items-center space-x-3">
                <span class="px-4 py-2 rounded-xl text-sm font-semibold text-white bg-blue-700">
                    Total: @totalItems
                </span>
                <button type="button" id="btn-add-new"
                        class="px-5 py-2 rounded-xl text-sm font-semibold text-white bg-green-600 hover:bg-green-700 shadow-md">
                    <i class="fa-solid fa-plus mr-2"></i> Add New
                </button>
            </div>
        </div>

        <div class="overflow-hidden border rounded-lg shadow-sm">
            <div class="max-h-96 overflow-y-auto">
                <table class="table-auto w-full text-sm">
                    <thead class="bg-gradient-to-r from-blue-700 to-blue-800 text-white sticky top-0">
                        <tr>
                            <th class="p-3 text-left">ID</th>
                            <th class="p-3 text-left">Date</th>
                            <th class="p-3 text-left">Customer</th>
                            <th class="p-3 text-left">Type</th>
                            <th class="p-3 text-left">Remarks</th>
                            <th class="p-3 text-right">Total</th>
                            <th class="p-3 text-right">Net Amount</th>
                            <th class="p-3 text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        @if (salesList != null && salesList.Any())
                        {
                            foreach (var item in salesList)
                            {
                                <tr class="hover:bg-blue-50 transition">
                                    <td class="p-3 font-semibold">@item.Id</td>
                                    <td class="p-3">@item.CurrentDate.ToString("dd-MMM-yyyy")</td>
                                    <td class="p-3 font-medium">@(item.CustomerName ?? "N/A")</td>
                                    <td class="p-3">
                                        <span class="px-2 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-800">
                                            @item.Etype
                                        </span>
                                    </td>
                                    <td class="p-3 text-gray-500">@(string.IsNullOrEmpty(item.Remarks) ? "-" : item.Remarks)</td>
                                    <td class="p-3 text-right font-semibold text-blue-700">@item.TotalAmount.ToString("N2")</td>
                                    <td class="p-3 text-right font-bold text-green-700">@item.NetAmount.ToString("N2")</td>
                                    <td class="p-3 text-center space-x-1">
                                        @* ✅ Edit → SalesReturn controller *@
                                        <a asp-action="Edit" asp-controller="SalesReturn"
                                           asp-route-id="@item.Id" asp-route-page="@currentPage" asp-route-pageSize="@pageSize"
                                           class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-medium bg-blue-100 text-blue-700 hover:bg-blue-200">
                                            <i class="fa-solid fa-edit mr-1"></i> Edit
                                        </a>
                                        @* ✅ Print → SalesReturn controller *@
                                        <a href="javascript:void(0)"
                                           onclick="window.open('/SalesReturn/PrintSalesReturnVoucher?id=@item.Id','_blank')"
                                           class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-medium bg-blue-600 text-white hover:bg-blue-700">
                                            <i class="fa-solid fa-print mr-1"></i> Print
                                        </a>
                                        @* ✅ Delete → SalesReturn controller *@
                                        @using (Html.BeginForm("Delete", "SalesReturn", FormMethod.Post,
                                            new { onsubmit = "return confirm('Are you sure?');", @class = "inline" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            @Html.Hidden("id", item.Id)
                                            <button type="submit"
                                                    class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-medium bg-red-100 text-red-700 hover:bg-red-200">
                                                <i class="fa-solid fa-trash mr-1"></i> Delete
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="p-10 text-center text-gray-400">
                                    <i class="fa-solid fa-inbox text-4xl block mb-2"></i>
                                    No sales return vouchers found
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (totalItems > 0)
        {
            <div class="flex justify-between items-center mt-6 pt-4 border-t">
                <div class="text-sm text-gray-600">
                    Showing <span class="font-semibold">@startItem</span>
                    to <span class="font-semibold">@endItem</span>
                    of <span class="font-semibold">@totalItems</span> entries
                </div>
                <div class="flex space-x-2">
                    @if (currentPage > 1)
                    {
                        @* ✅ SalesReturnVoucher action, SalesReturn controller *@
                        <a href="@Url.Action("SalesReturnVoucher", "SalesReturn", new { page = currentPage - 1, pageSize, activeTab = "list" })"
                           class="px-4 py-2 rounded-lg text-sm font-medium bg-blue-600 text-white hover:bg-blue-700">
                            <i class="fa-solid fa-chevron-left mr-1"></i> Previous
                        </a>
                    }
                    <span class="px-4 py-2 rounded-lg text-sm bg-gray-100 text-gray-700">
                        Page @currentPage of @totalPages
                    </span>
                    @if (endItem < totalItems)
                    {
                        <a href="@Url.Action("SalesReturnVoucher", "SalesReturn", new { page = currentPage + 1, pageSize, activeTab = "list" })"
                           class="px-4 py-2 rounded-lg text-sm font-medium bg-blue-600 text-white hover:bg-blue-700">
                            Next <i class="fa-solid fa-chevron-right ml-1"></i>
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>

@await Html.PartialAsync("_CustomerModal", new ERP.Models.Customer())
@await Html.PartialAsync("_WarehouseModal", new ERP.Models.Warehouse())
<div id="itemModalContainer"></div>

<script>
    function openCustomerModal()   { document.getElementById('customerModal').classList.remove('hidden'); }
    function closeCustomerModal()  { document.getElementById('customerModal').classList.add('hidden'); }
    function openWarehouseModal()  { document.getElementById('warehouseModal').classList.remove('hidden'); }
    function closeWarehouseModal() { document.getElementById('warehouseModal').classList.add('hidden'); }

    function openItemModal() {
        // ✅ SalesReturn controller
        fetch('/SalesReturn/ItemModal')
            .then(r => r.text())
            .then(html => {
                document.getElementById('itemModalContainer').innerHTML = html;
                document.getElementById('itemModal').classList.remove('hidden');
            })
            .catch(err => console.error('Modal load failed:', err));
    }
    function closeItemModal() {
        document.getElementById('itemModalContainer').innerHTML = '';
    }

    // MAIN TABS
    const tabForm     = document.getElementById("tab-form");
    const tabList     = document.getElementById("tab-list");
    const contentForm = document.getElementById("content-form");
    const contentList = document.getElementById("content-list");
    const btnAddNew   = document.getElementById("btn-add-new");

    tabForm.addEventListener("click",  () => showTab("form"));
    tabList.addEventListener("click",  () => showTab("list"));
    if (btnAddNew) btnAddNew.addEventListener("click", addNew);

    function showTab(tab) {
        if (tab === "form") {
            tabForm.classList.add("text-blue-900","border-b-2","border-blue-900");
            tabForm.classList.remove("text-gray-500");
            tabList.classList.remove("text-blue-900","border-b-2","border-blue-900");
            tabList.classList.add("text-gray-500");
            contentForm.classList.remove("hidden");
            contentList.classList.add("hidden");
        } else {
            tabList.classList.add("text-blue-900","border-b-2","border-blue-900");
            tabList.classList.remove("text-gray-500");
            tabForm.classList.remove("text-blue-900","border-b-2","border-blue-900");
            tabForm.classList.add("text-gray-500");
            contentList.classList.remove("hidden");
            contentForm.classList.add("hidden");
        }
    }

    function addNew() {
        resetForm();
        document.getElementById("StockMasterId").value = "0";
        showTab("form");
    }

    function resetForm() {
        document.querySelector("form").reset();
        details = [];
        renderTable();
        clearInputs();
        updateNetAmount();
    }


    // ✅ SalesReturn print action
    function printVoucher() {
        const id = document.getElementById("StockMasterId").value;
        if (parseInt(id) > 0) {
            window.open('/SalesReturn/PrintSalesReturnVoucher?id=' + id, '_blank');
        } else {
            alert("Please save the voucher first before printing.");
        }
    }

    // INNER TABS
    const tabStock      = document.getElementById("tab-stock-details");
    const tabCharges    = document.getElementById("tab-additional-charges");
    const contentStock  = document.getElementById("content-stock-details");
    const contentCharge = document.getElementById("content-additional-charges");

    tabStock.addEventListener("click",   () => showDetailTab("stock"));
    tabCharges.addEventListener("click", () => showDetailTab("charges"));

    function showDetailTab(tab) {
        if (tab === "stock") {
            tabStock.classList.add("text-blue-900","border-b-2","border-blue-900");
            tabStock.classList.remove("text-gray-500");
            tabCharges.classList.remove("text-blue-900","border-b-2","border-blue-900");
            tabCharges.classList.add("text-gray-500");
            contentStock.classList.remove("hidden");
            contentCharge.classList.add("hidden");
        } else {
            tabCharges.classList.add("text-blue-900","border-b-2","border-blue-900");
            tabCharges.classList.remove("text-gray-500");
            tabStock.classList.remove("text-blue-900","border-b-2","border-blue-900");
            tabStock.classList.add("text-gray-500");
            contentCharge.classList.remove("hidden");
            contentStock.classList.add("hidden");
        }
    }

    // ✅ SalesReturn controller ka GetSalesRate
    function fetchSalesRate() {
        const itemId = document.getElementById("itemId").value;
        if (!itemId) { document.getElementById("rate").value = ""; calculateAmounts(); return; }
        fetch(`@Url.Action("GetSalesRate","SalesReturn")?itemId=${itemId}`)
            .then(r => r.json())
            .then(data => {
                document.getElementById("rate").value = data.salesRate ? data.salesRate.toFixed(2) : "";
                calculateAmounts();
            })
            .catch(() => { document.getElementById("rate").value = ""; calculateAmounts(); });
    }

    // CALCULATIONS
    const qtyInput         = document.getElementById("qty");
    const rateInput        = document.getElementById("rate");
    const amountInput      = document.getElementById("amount");
    const discountPerInput = document.getElementById("discount_percentage");
    const discountAmtInput = document.getElementById("discount_amount");
    const netAmtInput      = document.getElementById("net_amount");

    qtyInput.addEventListener("input",         calculateAmounts);
    rateInput.addEventListener("input",        calculateAmounts);
    discountPerInput.addEventListener("input", calculateDiscount);

    function calculateAmounts() {
        const qty    = parseFloat(qtyInput.value)  || 0;
        const rate   = parseFloat(rateInput.value) || 0;
        const amount = qty * rate;
        amountInput.value      = amount.toFixed(2);
        discountPerInput.value = "";
        discountAmtInput.value = "0.00";
        netAmtInput.value      = amount.toFixed(2);
    }

    function calculateDiscount() {
        const amount = parseFloat(amountInput.value)      || 0;
        const per    = parseFloat(discountPerInput.value) || 0;
        const disc   = (amount * per) / 100;
        discountAmtInput.value = disc.toFixed(2);
        netAmtInput.value      = (amount - disc).toFixed(2);
    }

    // ADD DETAIL
    // ✅ Sales Return mein CheckItemQty nahi hoti (customer return kar raha hai)
    // ✅ Sirf basic validation - no stock restriction
    let details = [];

    document.getElementById("btnAddDetail").addEventListener("click", async () => {
        const warehouseId   = document.getElementById("warehouseId").value;
        const warehouseName = document.getElementById("warehouseId").selectedOptions[0]?.text ?? "";
        const itemId        = document.getElementById("itemId").value;
        const itemName      = document.getElementById("itemId").selectedOptions[0]?.text ?? "";
        const qty           = parseFloat(qtyInput.value)         || 0;
        const rate          = parseFloat(rateInput.value)        || 0;
        const amount        = parseFloat(amountInput.value)      || 0;
        const disc_per      = parseFloat(discountPerInput.value) || 0;
        const disc_amt      = parseFloat(discountAmtInput.value) || 0;
        const net_amount    = parseFloat(netAmtInput.value)      || 0;
        const currentDate   = document.querySelector('input[name="StockMaster.current_date"]').value;

        if (!warehouseId) { showAddMessage("Please select a warehouse.", false); return; }
        if (!itemId)      { showAddMessage("Please select an item.", false); return; }
        if (qty <= 0)     { showAddMessage("Please enter a valid quantity.", false); return; }
        if (rate <= 0)    { showAddMessage("Please enter a valid rate.", false); return; }

        // ✅ Sales Return → directly add karo, stock badhega
        details.push({ warehouseId, warehouseName, itemId, itemName, qty, rate, amount,
                       discount_percentage: disc_per, discount_amount: disc_amt, net_amount,
                       current_date: currentDate });
        renderTable();
        clearInputs();
        updateNetAmount();
        showAddMessage(`'${itemName}' added for return.`, true);
    });

    function showAddMessage(msg, isSuccess) {
        const div = document.getElementById("addMessage");
        div.className = `mt-2 px-4 py-2 rounded-lg text-sm font-semibold ${
            isSuccess ? "bg-green-100 text-green-700 border border-green-300"
                      : "bg-red-100 text-red-700 border border-red-300"}`;
        div.innerHTML = `<i class="fa-solid ${isSuccess ? 'fa-circle-check' : 'fa-circle-xmark'} mr-2"></i>${msg}`;
        div.classList.remove("hidden");
        setTimeout(() => div.classList.add("hidden"), 4000);
    }

    function renderTable() {
        const tbody     = document.querySelector("#detailsTable tbody");
        const container = document.getElementById("detailsContainer");
        tbody.innerHTML = ""; container.innerHTML = "";
        let totalAmount = 0, totalDiscount = 0, totalNet = 0;

        details.forEach((d, i) => {
            totalAmount   += d.amount;
            totalDiscount += d.discount_amount;
            totalNet      += d.net_amount;

            tbody.innerHTML += `
                <tr class="hover:bg-blue-50">
                    <td class="p-2 text-center">${i+1}</td>
                    <td class="p-2">${d.current_date}</td>
                    <td class="p-2">${d.warehouseName}</td>
                    <td class="p-2 font-medium">${d.itemName}</td>
                    <td class="p-2 text-right">${d.qty}</td>
                    <td class="p-2 text-right">${d.rate.toFixed(2)}</td>
                    <td class="p-2 text-right">${d.amount.toFixed(2)}</td>
                    <td class="p-2 text-right">${d.discount_percentage.toFixed(2)}</td>
                    <td class="p-2 text-right">${d.discount_amount.toFixed(2)}</td>
                    <td class="p-2 text-right font-semibold text-green-700">${d.net_amount.toFixed(2)}</td>
                    <td class="p-2 text-center">
                        <button type="button" onclick="removeDetail(${i})"
                                class="px-2 py-1 rounded bg-red-100 text-red-600 hover:bg-red-200 text-xs font-semibold">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </td>
                </tr>`;

            container.innerHTML += `
                <input type="hidden" name="StockDetail[${i}].warehouseId"         value="${d.warehouseId}" />
                <input type="hidden" name="StockDetail[${i}].itemId"              value="${d.itemId}" />
                <input type="hidden" name="StockDetail[${i}].qty"                 value="${d.qty}" />
                <input type="hidden" name="StockDetail[${i}].rate"                value="${d.rate}" />
                <input type="hidden" name="StockDetail[${i}].amount"              value="${d.amount}" />
                <input type="hidden" name="StockDetail[${i}].discount_percentage" value="${d.discount_percentage}" />
                <input type="hidden" name="StockDetail[${i}].discount_amount"     value="${d.discount_amount}" />
                <input type="hidden" name="StockDetail[${i}].net_amount"          value="${d.net_amount}" />
                <input type="hidden" name="StockDetail[${i}].current_date"        value="${d.current_date}" />`;
        });

        if (details.length > 0) {
            tbody.innerHTML += `
                <tr class="bg-red-50 font-semibold text-sm">
                    <td colspan="6" class="p-2 text-right">Total:</td>
                    <td class="p-2 text-right text-blue-700">${totalAmount.toFixed(2)}</td>
                    <td></td>
                    <td class="p-2 text-right text-blue-700">${totalDiscount.toFixed(2)}</td>
                    <td class="p-2 text-right text-green-700">${totalNet.toFixed(2)}</td>
                    <td></td>
                </tr>`;
        }
        document.querySelector('input[name="StockMaster.total_amount"]').value = totalNet.toFixed(2);
        updateNetAmount();
    }

    function removeDetail(i) {
        const name = details[i].itemName;
        details.splice(i, 1);
        renderTable();
        showAddMessage(`'${name}' removed.`, false);
    }

    function clearInputs() {
        ["warehouseId","itemId","qty","rate","amount","discount_percentage","discount_amount","net_amount"]
            .forEach(id => { const el = document.getElementById(id); if (el) el.value = ""; });
    }

    function updateNetAmount() {
        const total = parseFloat(document.querySelector('input[name="StockMaster.total_amount"]').value)    || 0;
        const disc  = parseFloat(document.querySelector('input[name="StockMaster.discount_amount"]').value) || 0;
        const tax   = parseFloat(document.querySelector('input[name="StockMaster.tax_amount"]').value)      || 0;
        document.querySelector('input[name="StockMaster.net_amount"]').value = (total - disc + tax).toFixed(2);
    }

    function beforeSave() {
        if (details.length === 0) {
            showAddMessage("Please add at least one item before saving.", false);
            showDetailTab("stock");
            return false;
        }
        updateNetAmount();
        return true;
    }

    // EDIT MODE
    @if (Model.StockMaster.Id > 0 && Model.StockDetail?.Any() == true)
    {
        var warehouses    = ViewBag.Warehouses as IEnumerable<dynamic>;
        var items         = ViewBag.Items      as IEnumerable<dynamic>;
        var warehouseDict = warehouses?.ToDictionary(w => (int)w.Id, w => (string)w.warehouse_name) ?? new Dictionary<int, string>();
        var itemDict      = items?.ToDictionary(i => (int)i.Id, i => (string)i.item_name)           ?? new Dictionary<int, string>();

        var jsonDetails = JsonSerializer.Serialize(Model.StockDetail.Select(d => new {
            warehouseId         = d.warehouseId,
            warehouseName       = warehouseDict.ContainsKey(d.warehouseId ?? 0) ? warehouseDict[d.warehouseId ?? 0] : "Unknown",
            itemId              = d.itemId,
            itemName            = itemDict.ContainsKey(d.itemId) ? itemDict[d.itemId] : "Unknown",
            qty                 = d.qty,
            rate                = d.rate,
            amount              = d.amount,
            discount_percentage = d.discount_percentage,
            discount_amount     = d.discount_amount,
            net_amount          = d.net_amount,
            current_date        = d.current_date.ToString("yyyy-MM-dd")
        }));
        <text>
        details = @Html.Raw(jsonDetails);
        renderTable();
        </text>
    }

    showTab('@activeTab');
</script>
